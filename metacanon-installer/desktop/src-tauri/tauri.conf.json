{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:4173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "MetaCanon Installer",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false
      }
    },
    "windows": [
      {
        "title": "MetaCanon Installer",
        "width": 1320,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "app",
      "identifier": "ai.metacanon.installer"
    }
  }
}
