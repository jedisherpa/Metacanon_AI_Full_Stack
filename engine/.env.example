# Copy this file to engine/.env and replace placeholder values.

# Core runtime
DATABASE_URL=postgresql://council:council@localhost:5432/council
PORT=3001
CORS_ORIGINS=http://localhost:5173
LENS_PACK=hands-of-the-void
ADMIN_PANEL_PASSWORD=change-me-strong-password

# Environment and runtime behavior
RUNTIME_ENV=local
LLM_PROVIDER_DEFAULT=kimi
MISSION_STUB_FALLBACK_ENABLED=true
INLINE_WORKER_ENABLED=true
# Runtime bridge wiring for /api/v1/runtime/* endpoints.
# When enabled, engine will try to load Installer bridge commands from the module path
# (supports either a file path or a Node module id).
# If disabled or unavailable, endpoints use in-memory fallback behavior.
METACANON_RUNTIME_BRIDGE_ENABLED=false
# METACANON_RUNTIME_BRIDGE_MODULE=../ffi-node/commands.js

# Governance + Sphere Thread boundary
GOVERNANCE_CONFIG_PATH=governance/governance.yaml
# GOVERNANCE_DIR=/absolute/path/to/custom/governance
CONDUCTOR_PRIVATE_KEY=dev-conductor-secret
# Optional Phase 2 dual-signing (Ed25519 + legacy HMAC). Set both together or leave both unset.
# Multi-line PEMs can use literal newlines or escaped `\n`.
# CONDUCTOR_ED25519_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# CONDUCTOR_ED25519_KEY_ID=conductor-key-2026-03
# Optional verifier key registry for rotated/historical keys (JSON keyId->PEM map).
# CONDUCTOR_ED25519_PUBLIC_KEYS_JSON={"conductor-key-2026-03":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}

# Optional strict ledger verification policy for V2 signatures.
SPHERE_LEDGER_REQUIRE_V2_SIGNATURE=false
# SPHERE_LEDGER_V2_ACTIVATION_AT=2026-03-10T00:00:00.000Z
SPHERE_LEDGER_V2_GRACE_DAYS=0
SPHERE_BFF_SERVICE_TOKEN=dev-sphere-bff-service-token
SPHERE_BFF_REQUIRE_AGENT_API_KEY_WRITES=false
# Format: principal=token,principal2=token2
SPHERE_BFF_AGENT_API_KEYS=
SPHERE_THREAD_ENABLED=true
SPHERE_C2_ALIAS_ENABLED=true
SPHERE_SIGNATURE_VERIFICATION=did_key
SPHERE_DB_ENFORCE_ROLE_SEPARATION=false
# Optional local; required in production. Must match a pre-created Postgres role
# when SPHERE_DB_ENFORCE_ROLE_SEPARATION=true and used by the app runtime
# so direct sphere_events writes remain blocked.
# Also ensure DATABASE_URL uses this same username (pre-connect startup check).
# SPHERE_DB_APP_ROLE=sphere_app

# Kimi (required by current env schema)
KIMI_API_KEY=replace-with-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
KIMI_ORCHESTRATOR_MODEL=moonshot-v1-32k
KIMI_FALLBACK_MODEL=moonshot-v1-8k

# Morpheus (optional/back-compat)
MORPHEUS_BASE_URL=https://api.openai.com/v1
MORPHEUS_API_KEY=placeholder
MORPHEUS_MODEL=gpt-4o-mini
MORPHEUS_ORCHESTRATOR_MODEL=gpt-4o-mini
MORPHEUS_FALLBACK_MODEL=gpt-4o-mini

# Groq (optional)
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=placeholder
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_ORCHESTRATOR_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_API_KEY=placeholder

# LLM retry/health behavior
LLM_RETRY_DELAY_MS=1000
LLM_HEALTH_CHECK_DELAY_MS=15000

# Deliberation defaults
DEFAULT_GROUP_SIZE=6
POSITION_REVEAL_SECONDS=15

# Admin session defaults
ADMIN_SESSION_COOKIE=admin_session
ADMIN_SESSION_TTL_HOURS=12
SESSION_SECURE_COOKIES=false

# Queue defaults
PG_BOSS_SCHEMA=pgboss
COMMAND_MAX_RETRIES=5

# Telegram Mini App (required for TMA auth flow)
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
WS_TOKEN_SECRET=replace-with-32-char-minimum-secret-value
# Local browser-only bypass (fast local testing without Telegram container/signature)
TELEGRAM_AUTH_DEV_BYPASS_ENABLED=false
TELEGRAM_AUTH_DEV_BYPASS_USER_ID=900000001
TELEGRAM_AUTH_DEV_BYPASS_FIRST_NAME=Local
TELEGRAM_AUTH_DEV_BYPASS_USERNAME=local_dev
# Telegram DB bridge (duplicates Telegram <-> Sphere messages)
TELEGRAM_MESSAGE_BRIDGE_ENABLED=false
TELEGRAM_BRIDGE_POLL_TIMEOUT_SECONDS=30
TELEGRAM_BRIDGE_ERROR_BACKOFF_MS=3000

# Skill adapter wiring (optional)
# Set these to enable live email_checking adapter integration.
# EMAIL_SKILL_ADAPTER_URL=http://127.0.0.1:3310
# EMAIL_SKILL_ADAPTER_TOKEN=replace-with-long-random-token
# Optional JSON map for credential refs used by the skill runtime:
# EMAIL_SKILL_SECRET_MAP_JSON={"secret://mail/main":"imap://user:pass@imap.example.com:993"}
# Alternative to secret map JSON:
# METACANON_SECRET_MAIL_MAIN=imap://user:pass@imap.example.com:993

# Email adapter service modes (used by `npm run dev:email-adapter`)
# EMAIL_ADAPTER_PROVIDER=stub
# EMAIL_ADAPTER_PORT=3310
# EMAIL_ADAPTER_HOST=127.0.0.1
# EMAIL_ADAPTER_TOKEN=replace-with-long-random-token
# Stub mode inbox fixture JSON: {"primary":[{"messageId":"m1","from":"ops@example.com","receivedAt":"2026-03-06T10:00:00.000Z"}]}
# EMAIL_ADAPTER_STUB_INBOX_JSON=
# Proxy mode (for external adapter/API):
# EMAIL_ADAPTER_PROVIDER=proxy
# EMAIL_ADAPTER_PROXY_URL=https://your-upstream-email-adapter
# EMAIL_ADAPTER_PROXY_TOKEN=optional-upstream-token
# IMAP mode (direct mailbox access through provided credential in `/fetch` payload):
# EMAIL_ADAPTER_PROVIDER=imap

# Optional observability
# SENTRY_DSN=
